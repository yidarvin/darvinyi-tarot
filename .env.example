# PostgreSQL connection string — provided automatically by Railway's Postgres plugin.
# For local dev: postgresql://user:password@localhost:5432/tarot
DATABASE_URL=postgresql://...

# Flask session signing key — any long random string.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Fernet key for encrypting user API keys at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Port the app listens on (Railway injects $PORT automatically; leave as 5000 for local dev).
PORT=5000
