# PostgreSQL connection string — provided automatically by Railway's Postgres plugin.
# For local dev: postgresql://user:password@localhost:5432/tarot
DATABASE_URL=postgresql://...

# Flask session signing key — any long random string.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Fernet key for encrypting user API keys at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Port the app listens on (Railway injects $PORT automatically; leave as 5000 for local dev).
PORT=5000

# Optional for local CLI usage in spread.py (web app uses each user's saved key instead).
# If set, spread.py can interpret cards and generate auto-titles for markdown exports.
ANTHROPIC_API_KEY=

# Optional: Claude model id for interpretations and onboarding (default: claude-sonnet-4-6).
# ANTHROPIC_MODEL=

# Optional local path for CLI markdown exports from spread.py.
PATH_TO_SAVE=
